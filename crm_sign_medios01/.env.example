# Example environment variables for local development
# Copy this to .env and fill with real values. Do NOT commit .env

# Meta app credentials
FACEBOOK_APP_ID="your_facebook_app_id"
FACEBOOK_APP_SECRET="your_facebook_app_secret"

# Embedded signup redirect URI configured in your Meta app
EMBEDDED_REDIRECT_URI="https://localhost/"

# Frontend (Vite) variable
VITE_FACEBOOK_APP_ID="your_facebook_app_id"

# Local Postgres (used by server/migrate and persistence)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/embedded_signup"

# Optional: for quick e2e runs you can provide a short-lived token
SHORT_LIVED_TOKEN=""
# or the `code` returned by the Embedded Signup redirect
EMBEDDED_SIGNUP_CODE=""

# JSON string for session info used by e2e script
# TEST_SESSION_INFO='{"phone_number":"+123","waba_id":"<WABA_ID>","companyName":"Test Co"}'

# Logging
LOG_LEVEL="info"
